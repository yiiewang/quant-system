# MACD 量化交易系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Tushare API Token（如使用 tushare 数据源）
TUSHARE_TOKEN=your_tushare_token_here

# 日志级别
LOG_LEVEL=INFO

# 数据目录
DATA_DIR=data

# 配置文件路径
CONFIG_PATH=config/default.yaml

# SMTP 邮件服务配置
# QQ邮箱: smtp.qq.com (端口 465, SSL=true)
# 163邮箱: smtp.163.com (端口 465, SSL=true)
# Gmail:   smtp.gmail.com (端口 587, SSL=false)
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=your_qq_number@qq.com
SMTP_PASS=your_authorization_code
