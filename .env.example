# MACD 量化交易系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 环境变量优先级: 环境变量 > YAML 配置文件 > 默认值

# ==================== 数据配置 ====================
# Tushare API Token（如使用 tushare 数据源）
# 格式: {PREFIX}_DATA_API_TOKENS_TUSHARE
APP_DATA_API_TOKENS_TUSHARE=your_tushare_token_here

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
# 格式: {PREFIX}_LOG_LEVEL
APP_LOG_LEVEL=INFO

# ==================== 通知配置 ====================
# 通知总开关
# 格式: {PREFIX}_NOTIFICATION_ENABLED
APP_NOTIFICATION_ENABLED=false

# 邮件通知配置
# QQ邮箱: smtp.qq.com (端口 465, SSL=true)
# 163邮箱: smtp.163.com (端口 465, SSL=true)
# Gmail:   smtp.gmail.com (端口 587, SSL=false)
APP_NOTIFICATION_EMAIL_ENABLED=true
APP_NOTIFICATION_EMAIL_SMTP_SERVER=smtp.qq.com
APP_NOTIFICATION_EMAIL_SMTP_PORT=465
APP_NOTIFICATION_EMAIL_USE_SSL=true
APP_NOTIFICATION_EMAIL_USERNAME=your_email@qq.com
APP_NOTIFICATION_EMAIL_PASSWORD=your_authorization_code
APP_NOTIFICATION_EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com
APP_NOTIFICATION_EMAIL_SENDER_NAME=量化交易系统

# Webhook 通知配置（企业微信/钉钉/飞书）
APP_NOTIFICATION_WEBHOOK_ENABLED=false
APP_NOTIFICATION_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key
APP_NOTIFICATION_WEBHOOK_TYPE=wecom

# ==================== 交易配置 ====================
# 交易模式: paper, live, backtest
APP_TRADING_MODE=paper
APP_TRADING_INITIAL_CAPITAL=100000

# ==================== 风控配置 ====================
APP_RISK_MAX_POSITION_PCT=0.3
APP_RISK_STOP_LOSS_PCT=0.05
APP_RISK_TAKE_PROFIT_PCT=0.15

# ==================== API 配置 ====================
APP_API_HOST=0.0.0.0
APP_API_PORT=8000
APP_API_DEBUG=false

# ==================== 旧版配置（已废弃）====================
# 以下配置已不再使用，请使用上面的新格式
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your_email@qq.com
# SMTP_PASS=your_password
