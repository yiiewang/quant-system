# MACD 量化交易系统 - Git 忽略配置

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 项目数据（仅忽略仓库根目录运行产物）
/data/
/logs/
/output/
*.db
*.sqlite
*.sqlite3

# 明确保留源码目录
!/src/data/
!/src/data/**

# 配置（包含敏感信息）
.env
config/local.yaml
config/prod.yaml

# 测试
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# 其他
*.log
*.tmp
.DS_Store
Thumbs.db

# src/data 下仍忽略编译产物
/src/data/__pycache__/
/src/data/*.py[cod]
